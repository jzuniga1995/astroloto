    const signos = ["Avión","Pies","Mujer","Muerto","Tigre","Embarazada","Elefante","Navaja","Conejo","Hombre","Anillo","Perro","Caballo","Gato","Boda","Ratón","Niña","Joven","Ángel","Mariposa","Espejo","Pájaro","Ataúd","Mono","Sapo","Balanza","Bandera","Juego","Gallo","Padre","Bolo","Alacrán","Culebra","Carpintero","Música","Virgen","Ciejita","Suerte","Pistola","Jabón","Cielo","Novia","Madre","Pantera","Mesas","Iglesia","Familia","Banco","Estrella","Sombra","Luna Nueva","Policía","Zorrillo","Llanta","Licor","Olas","Árbol","Cuchillo","Venado","Selva","Dragón","Guerra","Lagarto","Coco","Mueble","Pintura","Diablo","Vaca","Ladrón","Soldado","Oro","Zapatos","Arco","Fuego","Edificio","Reina","Palomas","Humo","Tienda","Flores","Café","Rieles","Escuela","Bote","Coronas","Casa","Reloj","León","Platos","Búho","Lentes","Tortuga","Águila","Cartero","Carro","Costurera","Dinero","Viejito","Bailes","Aretes"];

    function resaltarSigno(num, nombre) {
      document.getElementById('buscarNumero').value = num;
      document.getElementById('buscarSueno').value = '';
      const resultadoDiv   = document.getElementById('resultadoDestacado');
      const textoResultado = document.getElementById('textoResultado');
      resultadoDiv.classList.remove('hidden');
      textoResultado.textContent = `${String(num).padStart(2,'0')} → ${signos[num]}`;
      filtrarTabla();
      document.getElementById('tablaSignos').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function filtrarTabla() {
      const busquedaSueno  = document.getElementById('buscarSueno').value.toLowerCase().trim();
      const busquedaNumero = document.getElementById('buscarNumero').value.trim();
      const filas          = document.querySelectorAll('.fila-signo');
      const resultadoDiv   = document.getElementById('resultadoDestacado');
      const textoResultado = document.getElementById('textoResultado');
      const sinResultados  = document.getElementById('sinResultados');
      const contador       = document.getElementById('contadorResultados');

      let visibles    = 0;
      let matchExacto = null;

      if (busquedaNumero !== '' && !busquedaSueno) {
        const num = parseInt(busquedaNumero);
        if (num >= 0 && num <= 99) {
          matchExacto = `${String(num).padStart(2,'0')} → ${signos[num]}`;
        }
      }

      if (busquedaSueno && !busquedaNumero) {
        const encontrado = signos.findIndex(s => s.toLowerCase() === busquedaSueno);
        if (encontrado !== -1) {
          matchExacto = `${String(encontrado).padStart(2,'0')} → ${signos[encontrado]}`;
        }
      }

      if (matchExacto) {
        resultadoDiv.classList.remove('hidden');
        textoResultado.textContent = matchExacto;
      } else if (!busquedaSueno && !busquedaNumero) {
        resultadoDiv.classList.add('hidden');
      }

      filas.forEach(fila => {
        const sueno1  = fila.dataset.sueno1.toLowerCase();
        const sueno2  = fila.dataset.sueno2.toLowerCase();
        const num1    = fila.dataset.numero1;
        const num2    = fila.dataset.numero2;

        const matchSueno  = !busquedaSueno  || sueno1.includes(busquedaSueno)  || sueno2.includes(busquedaSueno);
        const matchNumero = !busquedaNumero || num1 === busquedaNumero || num2 === busquedaNumero;

        if (matchSueno && matchNumero) {
          fila.classList.remove('hidden');
          visibles++;
        } else {
          fila.classList.add('hidden');
        }
      });

      const total = visibles * 2;
      contador.textContent = `${total} signo${total !== 1 ? 's' : ''}`;
      sinResultados.classList.toggle('hidden', visibles > 0);
    }
  </script>
</Layout>
