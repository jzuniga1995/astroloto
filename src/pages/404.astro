---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
import {  Home, History } from 'lucide-astro';
---

<Layout>
    <Fragment slot="head">
        <title>Página no encontrada – LotoHN</title>
        <meta name="robots" content="noindex, nofollow" />
        <meta name="theme-color" content="#667eea" />

        <style>
            .error-hero {
                text-align: center;
                padding: 3rem 1rem 2rem;
            }

            .error-numero {
                font-size: clamp(6rem, 20vw, 10rem);
                font-weight: 900;
                line-height: 1;
                background: linear-gradient(135deg, #7C3AED, #9333EA, #C026D3);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin-bottom: 0.5rem;
                animation: pulse-num 2s ease-in-out infinite;
            }

            @keyframes pulse-num {
                0%, 100% { opacity: 1; }
                50%       { opacity: 0.7; }
            }

            .bolas-404 {
                display: flex;
                justify-content: center;
                gap: 1rem;
                margin: 1.5rem 0;
                flex-wrap: wrap;
            }

            .bola-404 {
                width: 64px;
                height: 64px;
                border-radius: 50%;
                background: linear-gradient(135deg, #7C3AED, #9333EA);
                color: #fff;
                font-size: 1.4rem;
                font-weight: 800;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 8px 20px rgba(124, 58, 237, 0.35);
                animation: bounce-ball 1.2s ease-in-out infinite;
            }

            .bola-404:nth-child(2) { animation-delay: 0.2s; background: linear-gradient(135deg, #9333EA, #C026D3); }
            .bola-404:nth-child(3) { animation-delay: 0.4s; background: linear-gradient(135deg, #C026D3, #DB2777); }

            @keyframes bounce-ball {
                0%, 100% { transform: translateY(0); }
                50%       { transform: translateY(-12px); }
            }

            .error-links {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                justify-content: center;
                margin-top: 2rem;
            }

            .error-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.75rem 1.5rem;
                border-radius: 9999px;
                font-weight: 600;
                font-size: 0.95rem;
                transition: transform 0.2s, box-shadow 0.2s;
                text-decoration: none;
            }

            .error-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3);
            }

            .error-btn-primary {
                background: linear-gradient(135deg, #7C3AED, #9333EA);
                color: #fff;
            }

            .error-btn-secondary {
                background: #F5F3FF;
                color: #7C3AED;
                border: 2px solid #EDE9FE;
            }
        </style>
    </Fragment>

    <div class="bg-white rounded-2xl shadow-xl p-6 md:p-12 text-center error-hero">

        <!-- Número 404 animado -->
        <div class="error-numero">404</div>

        <!-- Bolas animadas -->
        <div class="bolas-404">
            <div class="bola-404">4</div>
            <div class="bola-404">0</div>
            <div class="bola-404">4</div>
        </div>

        <!-- Mensaje -->
        <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-3">
            ¡Este número no salió sorteado!
        </h1>
        <p class="text-gray-500 text-base md:text-lg max-w-md mx-auto mb-2">
            La página que buscas no existe o fue movida. Pero no te preocupes, los resultados de hoy sí están disponibles.
        </p>

        <!-- Links -->
        <div class="error-links">
            <a href="/" class="error-btn error-btn-primary">
                <Home class="w-5 h-5" />
                Ver Resultados de Hoy
            </a>
            <a href="/historial" class="error-btn error-btn-secondary">
                <History class="w-5 h-5" />
                Ver Historial
            </a>
        </div>

    </div>
</Layout>

