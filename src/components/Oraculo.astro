---
// src/components/Oraculo.astro
---

<div id="oraculo-root" class="oraculo-root" aria-label="Cábala del día">

    <!-- Skeleton -->
    <div class="oraculo-skeleton" id="oraculo-skeleton">
        <div class="sk-toprow">
            <div class="sk-dot"></div>
            <div class="sk-line" style="width:36%"></div>
            <div class="sk-pill"></div>
        </div>
        <div class="sk-line" style="width:90%;margin-top:.8rem"></div>
        <div class="sk-line" style="width:65%;margin-top:.4rem"></div>
        <div class="sk-balls">
            <div class="sk-ball"></div>
            <div class="sk-ball" style="animation-delay:.15s"></div>
            <div class="sk-ball" style="animation-delay:.3s"></div>
        </div>
    </div>

    <!-- Card -->
    <div class="oraculo-card" id="oraculo-card" style="display:none">

        <div class="o-header">
            <div class="o-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.4"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1"  x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22"   x2="5.64"  y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1"  y1="12" x2="3"  y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/>
                    <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
                </svg>
            </div>
            <div class="o-meta">
                <span class="o-label">Cábala del Día</span>
                <span class="o-fecha" id="oraculo-fecha"></span>
            </div>
            <div class="o-badge" id="oraculo-badge"></div>
        </div>

        <p class="o-acertijo" id="oraculo-acertijo"></p>

        <div class="o-bottom">
            <div class="o-balls-block">
                <span class="o-balls-label">Números de la suerte</span>
                <div class="o-balls" id="oraculo-nums"></div>
            </div>
            <p class="o-frase" id="oraculo-frase"></p>
        </div>

    </div>

    <!-- Error -->
    <div class="oraculo-error" id="oraculo-error" style="display:none">
        🍀 No hay cábala disponible hoy. Volvé más tarde.
    </div>
</div>

<style>
    /* ── Wrapper centrado y acotado ── */
    .oraculo-root {
        --ca:    #16a34a;
        --cb:    #86efac;
        --ca-rgb: 22,163,74;
        font-family: inherit;
        width: 100%;
        max-width: 580px;       /* no se estira a lo largo */
        margin-inline: auto;    /* centrado */
    }

    /* ── Skeleton ── */
    .oraculo-skeleton {
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 1rem;
        padding: .9rem 1.2rem 1rem;
    }
    .sk-toprow { display:flex; align-items:center; gap:.55rem; }
    .sk-dot  { width:1.6rem; height:1.6rem; border-radius:50%;
               background:rgba(0,0,0,.08); flex-shrink:0; animation:sk-s 1.5s ease-in-out infinite; }
    .sk-pill { width:3.8rem; height:1rem; border-radius:2rem;
               background:rgba(0,0,0,.08); margin-left:auto; animation:sk-s 1.5s ease-in-out infinite; }
    .sk-line { height:.58rem; border-radius:.4rem;
               background:linear-gradient(90deg,rgba(0,0,0,.05) 25%,rgba(0,0,0,.1) 50%,rgba(0,0,0,.05) 75%);
               background-size:200% 100%; animation:sk-s 1.5s ease-in-out infinite; }
    .sk-balls { display:flex; gap:.7rem; margin-top:1.1rem; }
    .sk-ball  { width:3rem; height:3rem; border-radius:50%;
                background:rgba(0,0,0,.08); animation:sk-s 1.5s ease-in-out infinite; }
    @keyframes sk-s {
        0%,100% { background-position:200% center; opacity:.7; }
        50%      { opacity:1; }
    }

    /* ── Card ── */
    .oraculo-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.09);
        border-radius: 1rem;
        overflow: hidden;
        position: relative;
        /* línea de color arriba según el día */
        box-shadow:
            inset 0 3px 0 var(--ca),
            0 2px 8px rgba(0,0,0,.07);
        animation: oc-in .4s cubic-bezier(.22,1,.36,1) both;
    }
    @keyframes oc-in {
        from { opacity:0; transform:translateY(6px); }
        to   { opacity:1; transform:translateY(0); }
    }
    /* tinte de fondo muy sutil */
    .oraculo-card::before {
        content:'';
        position:absolute; inset:0;
        background: linear-gradient(160deg,
            rgba(var(--ca-rgb),.06) 0%, transparent 55%);
        pointer-events:none; z-index:0;
    }

    /* ── Header ── */
    .o-header {
        display:flex; align-items:center; gap:.55rem;
        padding: .8rem 1.2rem .55rem;
        position:relative; z-index:1;
    }
    .o-icon {
        width:1.7rem; height:1.7rem; border-radius:50%;
        background: rgba(var(--ca-rgb),.15);
        color:var(--ca);
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0;
    }
    .o-meta { display:flex; flex-direction:column; gap:.05rem; flex:1; min-width:0; }
    .o-label {
        font-size:.67rem; font-weight:800;
        text-transform:uppercase; letter-spacing:.07em;
        color:var(--ca); line-height:1;
    }
    .o-fecha { font-size:.6rem; color:#9ca3af; font-weight:500; }
    .o-badge {
        font-size:.54rem; font-weight:900; letter-spacing:.05em;
        text-transform:uppercase; color:var(--ca);
        background: rgba(var(--ca-rgb),.1);
        border: 1px solid rgba(var(--ca-rgb),.3);
        padding:.18rem .55rem; border-radius:2rem;
        white-space:nowrap; flex-shrink:0;
    }

    /* ── Acertijo ── */
    .o-acertijo {
        font-size:clamp(.84rem,2.6vw,.95rem);
        line-height:1.65; color:#374151;
        font-style:italic; margin:0;
        padding:.05rem 1.2rem .75rem;
        position:relative; z-index:1;
    }

    /* ── Bottom ── */
    .o-bottom {
        display:flex; align-items:center;
        gap:1rem; flex-wrap:wrap;
        padding:.7rem 1.2rem .95rem;
        border-top:1px solid rgba(0,0,0,.05);
        position:relative; z-index:1;
    }

    /* ── Bolas ── */
    .o-balls-block {
        display:flex; flex-direction:column; gap:.5rem;
        flex-shrink:0;
    }
    .o-balls-label {
        font-size:.57rem; font-weight:700;
        text-transform:uppercase; letter-spacing:.07em;
        color:#9ca3af;
    }
    .o-balls { display:flex; gap:.6rem; align-items:center; }

    .o-ball {
        /* Bola grande tipo lotería */
        width:  3rem;
        height: 3rem;
        border-radius: 50%;

        /* Gradiente esférico: destello arriba-izq → color base → oscuro abajo */
        background:
            radial-gradient(circle at 33% 28%,
                #fff               0%,
                var(--cb)         28%,
                var(--ca)         62%,
                rgba(0,0,0,.25)  100%);

        display:flex; align-items:center; justify-content:center;

        font-size: 1rem;
        font-weight: 900;
        color: #fff;
        text-shadow: 0 1px 4px rgba(0,0,0,.4);

        /* Sombra que da profundidad */
        box-shadow:
            0 6px 16px rgba(var(--ca-rgb),.35),
            0 2px 4px  rgba(0,0,0,.15),
            inset 0 -4px 8px  rgba(0,0,0,.22),
            inset 0  3px 6px  rgba(255,255,255,.4);

        position: relative;
        animation: ball-in .45s cubic-bezier(.34,1.56,.64,1) both;
        cursor: default;
        transition: transform .15s ease, box-shadow .15s ease;
    }
    .o-ball:hover {
        transform: translateY(-3px) scale(1.08);
        box-shadow:
            0 10px 24px rgba(var(--ca-rgb),.4),
            0 3px 6px   rgba(0,0,0,.15),
            inset 0 -4px 8px  rgba(0,0,0,.22),
            inset 0  3px 6px  rgba(255,255,255,.4);
    }

    /* Brillo superior */
    .o-ball::before {
        content:'';
        position:absolute;
        top:16%; left:20%;
        width:30%; height:20%;
        background:rgba(255,255,255,.55);
        border-radius:50%;
        filter:blur(2px);
        transform:rotate(-20deg);
        pointer-events:none;
    }

    .o-ball:nth-child(1) { animation-delay:.1s; }
    .o-ball:nth-child(2) { animation-delay:.22s; }
    .o-ball:nth-child(3) { animation-delay:.36s; }

    @keyframes ball-in {
        from { opacity:0; transform:scale(.35) translateY(10px); }
        to   { opacity:1; transform:scale(1) translateY(0); }
    }

    /* ── Frase ── */
    .o-frase {
        flex:1; min-width:120px;
        font-size:clamp(.72rem,2.2vw,.8rem);
        color:#6b7280; font-style:italic; font-weight:600;
        margin:0; line-height:1.45;
        padding-left:.75rem;
        border-left:2px solid rgba(var(--ca-rgb),.35);
    }

    /* ── Error ── */
    .oraculo-error {
        font-size:.8rem; color:#9ca3af;
        padding:.8rem 1rem;
        border:1px dashed rgba(0,0,0,.1);
        border-radius:1rem; text-align:center;
    }
</style>

<script>
(async () => {

    /* Paletas por día — solo necesitamos --ca (color base), --cb (claro), --ca-rgb */
    const TEMAS: Record<number, { badge:string; ca:string; cb:string; rgb:string; }> = {
        0: { badge:'Super Premio', ca:'#c2410c', cb:'#fed7aa', rgb:'194,65,12'  },
        1: { badge:'Jugá 3',       ca:'#1d4ed8', cb:'#bfdbfe', rgb:'29,78,216'  },
        2: { badge:'Pega 3',       ca:'#0891b2', cb:'#a5f3fc', rgb:'8,145,178'  },
        3: { badge:'Premia 2',     ca:'#7c3aed', cb:'#ddd6fe', rgb:'124,58,237' },
        4: { badge:'La Diaria',    ca:'#16a34a', cb:'#bbf7d0', rgb:'22,163,74'  },
        5: { badge:'Jugá 3',       ca:'#1d4ed8', cb:'#bfdbfe', rgb:'29,78,216'  },
        6: { badge:'Super Premio', ca:'#c2410c', cb:'#fed7aa', rgb:'194,65,12'  },
    };

    function aplicarTema(dia: number) {
        const t = TEMAS[dia] ?? TEMAS[4];
        const root = document.getElementById('oraculo-root') as HTMLElement;
        root.style.setProperty('--ca',     t.ca);
        root.style.setProperty('--cb',     t.cb);
        root.style.setProperty('--ca-rgb', t.rgb);
        const badge = document.getElementById('oraculo-badge');
        if (badge) badge.textContent = t.badge;
    }

    const skeleton = document.getElementById('oraculo-skeleton') as HTMLElement;
    const card     = document.getElementById('oraculo-card')     as HTMLElement;
    const error    = document.getElementById('oraculo-error')    as HTMLElement;

    function mostrarError() {
        skeleton.style.display = 'none';
        error.style.display    = 'block';
    }

    try {
        const resp = await fetch('/api/oraculo', { cache: 'no-store' });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();
        if (!data?.acertijo) throw new Error('Sin datos');

        let diaSemana = new Date().getDay();

        if (data.fecha) {
            const [y, m, d] = (data.fecha as string).split('-').map(Number);
            const fecha = new Date(y, m - 1, d);
            diaSemana   = fecha.getDay();
            const dias  = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
            const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
            (document.getElementById('oraculo-fecha') as HTMLElement).textContent =
                `${dias[fecha.getDay()]} ${d} de ${meses[m-1]}`;
        }

        aplicarTema(diaSemana);

        (document.getElementById('oraculo-acertijo') as HTMLElement).textContent = data.acertijo;

        const ballsEl = document.getElementById('oraculo-nums') as HTMLElement;
        ((data.numeros || []) as number[]).forEach((n: number) => {
            const ball = document.createElement('div');
            ball.className   = 'o-ball';
            ball.textContent = String(n);
            ballsEl.appendChild(ball);
        });

        if (data.frase) {
            (document.getElementById('oraculo-frase') as HTMLElement).textContent = data.frase;
        }

        skeleton.style.display = 'none';
        card.style.display     = 'block';

    } catch (e) {
        aplicarTema(new Date().getDay());
        console.warn('Oráculo:', (e as Error).message);
        mostrarError();
    }
})();
</script>
